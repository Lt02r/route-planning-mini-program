/* pages/ai-route/ai-route.wxss */
.page {
  background: #F5F7FA;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* AI Banner */
.ai-banner {
  background: linear-gradient(135deg, #722ED1 0%, #531DAB 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.ai-banner-icon {
  font-size: 72rpx;
  line-height: 1;
}

.ai-banner-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.ai-banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* Section Card */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #303133;
  margin-bottom: 20rpx;
}

.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #C0C4CC;
}

/* Setting Group */
.setting-group {
  margin-bottom: 28rpx;
}

.setting-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #303133;
  margin-bottom: 16rpx;
}

.setting-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #722ED1;
}

.time-slider {
  margin: 0 -8rpx;
}

.slider-range {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #C0C4CC;
  margin-top: 4rpx;
}

.estimate-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F9F0FF;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.estimate-icon {
  font-size: 32rpx;
}

.estimate-text {
  font-size: 26rpx;
  color: #606266;
}

.estimate-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #722ED1;
}

/* Travel Mode */
.travel-mode-group {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.travel-mode-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #E4E7ED;
  border-radius: 12rpx;
  gap: 8rpx;
  font-size: 26rpx;
  color: #606266;
  transition: all 0.2s;
}

.travel-mode-item.active {
  border-color: #722ED1;
  color: #722ED1;
  background: #F9F0FF;
}

.travel-icon {
  font-size: 48rpx;
}

/* Category Preference */
.category-pref-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-pref-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border: 2rpx solid transparent;
  border-radius: 30rpx;
  background: #F5F7FA;
  transition: all 0.2s;
}

.category-pref-item.active {
  border-color: #722ED1;
  background: #F9F0FF;
}

.pref-check {
  color: #722ED1;
  font-size: 24rpx;
  font-weight: 700;
}

/* Generate Button */
.generate-section {
  margin-bottom: 20rpx;
}

.generate-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #722ED1 0%, #531DAB 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.generate-btn.generating {
  opacity: 0.7;
}

/* Result Card */
.result-card {
  border: 2rpx solid #F9F0FF;
}

.result-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.result-summary {
  font-size: 24rpx;
  color: #909399;
  text-align: right;
  line-height: 1.4;
}

.route-map {
  width: 100%;
  height: 380rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 28rpx;
}

/* Timeline */
.route-timeline {
  margin-bottom: 32rpx;
}

.timeline-item {
  display: flex;
  gap: 16rpx;
  min-height: 80rpx;
}

.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
}

.timeline-dot {
  width: 48rpx;
  height: 48rpx;
  background: #722ED1;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.timeline-line {
  flex: 1;
  width: 2rpx;
  background: #E4E7ED;
  margin: 8rpx 0;
  min-height: 32rpx;
}

.timeline-content {
  flex: 1;
  padding-bottom: 24rpx;
}

.timeline-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 10rpx;
}

.timeline-meta {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.timeline-addr {
  font-size: 22rpx;
  color: #909399;
  margin-bottom: 6rpx;
}

.timeline-note {
  font-size: 22rpx;
  color: #909399;
  margin-bottom: 6rpx;
}

.timeline-time {
  font-size: 22rpx;
  color: #722ED1;
}

.apply-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  background: #1677FF;
  color: #fff;
  border: none;
}
