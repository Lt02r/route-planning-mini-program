/* pages/marker-edit/marker-edit.wxss */
.page {
  padding: 24rpx;
  min-height: 100vh;
  background: #F5F7FA;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 16rpx;
}

.form-label.required::after {
  content: ' *';
  color: #F56C6C;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #DCDFE6;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #303133;
  background: #fff;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: #1677FF;
}

/* Location */
.location-box {
  border: 2rpx solid #DCDFE6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  min-height: 80rpx;
}

.location-selected {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.location-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.location-info {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
  line-height: 1.4;
}

.location-change {
  font-size: 26rpx;
  color: #1677FF;
  flex-shrink: 0;
}

.location-empty {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #C0C4CC;
  font-size: 28rpx;
}

/* Category */
.category-select {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-opt {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  background: #F5F7FA;
  font-size: 26rpx;
  color: #606266;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.category-opt.active {
  background: #E8F4FF;
  color: #1677FF;
  border-color: #1677FF;
}

/* Priority */
.priority-select {
  display: flex;
  gap: 20rpx;
}

.priority-opt {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  font-size: 26rpx;
  color: #606266;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.priority-opt-0.active {
  background: #F5F5F5;
  color: #909399;
  border-color: #909399;
}

.priority-opt-1.active {
  background: #FFF7E8;
  color: #E6A23C;
  border-color: #E6A23C;
}

.priority-opt-2.active {
  background: #FFECEC;
  color: #F56C6C;
  border-color: #F56C6C;
}

/* Textarea */
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #DCDFE6;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #303133;
  background: #fff;
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #C0C4CC;
  margin-top: 8rpx;
}

/* Actions */
.form-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 0 40rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.action-btn.disabled {
  opacity: 0.6;
}
