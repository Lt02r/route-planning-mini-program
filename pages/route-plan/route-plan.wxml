<!-- pages/route-plan/route-plan.wxml -->
<scroll-view class="page" scroll-y scroll-into-view="{{showRoute ? 'route-result' : ''}}">
  <!-- Marker Selection -->
  <view class="section-card">
    <view class="section-header">
      <view class="section-title">选择标点</view>
      <view class="header-actions">
        <text class="link" bind:tap="onSelectAll">全选</text>
        <text class="link link-danger" bind:tap="onClearSelection">清空</text>
      </view>
    </view>
    <text class="section-desc">已选 {{selectedIds.length}} / {{allMarkers.length}} 个标点</text>

    <view wx:if="{{allMarkers.length > 0}}" class="marker-select-list">
      <view
        wx:for="{{allMarkers}}"
        wx:key="id"
        class="marker-select-item {{selectedIds.indexOf(item.id) !== -1 ? 'selected' : ''}}"
        data-id="{{item.id}}"
        bind:tap="onToggleMarker"
      >
        <view class="marker-select-check">
          <view class="check-box {{selectedIds.indexOf(item.id) !== -1 ? 'checked' : ''}}">
            <text wx:if="{{selectedIds.indexOf(item.id) !== -1}}" class="check-mark">✓</text>
          </view>
        </view>
        <view class="marker-select-info">
          <view class="marker-select-name">{{item.name}}</view>
          <view class="marker-select-meta">
            <view class="tag tag-{{item.category}}">{{item.category}}</view>
            <view class="priority-badge priority-{{item.priority}}">{{priorityLabels[item.priority]}}</view>
          </view>
          <view wx:if="{{item.address}}" class="marker-select-addr">📍 {{item.address}}</view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text style="font-size:60rpx">📍</text>
      <text>暂无标点，请先添加标点</text>
    </view>
  </view>

  <!-- Travel Mode -->
  <view class="section-card">
    <view class="section-title">出行方式</view>
    <view class="travel-mode-group">
      <view
        class="travel-mode-item {{travelMode === 'driving' ? 'active' : ''}}"
        data-mode="driving"
        bind:tap="onTravelModeChange"
      >
        <text class="travel-icon">🚗</text>
        <text>驾车</text>
      </view>
      <view
        class="travel-mode-item {{travelMode === 'walking' ? 'active' : ''}}"
        data-mode="walking"
        bind:tap="onTravelModeChange"
      >
        <text class="travel-icon">🚶</text>
        <text>步行</text>
      </view>
    </view>
  </view>

  <!-- Action Buttons -->
  <view class="action-row">
    <button class="btn-plain action-btn" bind:tap="onPlanRoute">
      按选择顺序规划
    </button>
    <button class="btn-primary action-btn" bind:tap="onOptimizeRoute">
      🔄 智能优化路线
    </button>
  </view>

  <!-- Route Result -->
  <view id="route-result" wx:if="{{showRoute}}" class="section-card route-result">
    <view class="section-header">
      <view class="section-title">路线结果</view>
      <view wx:if="{{optimized}}" class="optimized-badge">已优化</view>
    </view>

    <!-- Route Stats -->
    <view class="route-stats">
      <view class="stat-item">
        <view class="stat-value">{{routeMarkers.length}}</view>
        <view class="stat-label">个地点</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{totalDistanceText}}</view>
        <view class="stat-label">总距离</view>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-value">{{totalTimeText}}</view>
        <view class="stat-label">预计{{travelMode === 'driving' ? '驾车' : '步行'}}时间</view>
      </view>
    </view>

    <!-- Route Map -->
    <map
      class="route-map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{mapMarkers}}"
      polyline="{{mapPolylines}}"
      enable-zoom
      enable-scroll
    ></map>

    <!-- Route Steps -->
    <view class="route-steps">
      <view
        wx:for="{{routeMarkers}}"
        wx:key="id"
        class="route-step"
      >
        <view class="step-number">{{index + 1}}</view>
        <view class="step-content">
          <view class="step-name">{{item.name}}</view>
          <view class="step-meta">
            <view class="tag tag-{{item.category}}">{{item.category}}</view>
            <view wx:if="{{item.address}}" class="step-addr">{{item.address}}</view>
          </view>
          <view wx:if="{{item.note}}" class="step-note">📝 {{item.note}}</view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
