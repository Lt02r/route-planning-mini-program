/* pages/index/index.wxss */
.container {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* Category filter bar */
.category-bar {
  width: 100%;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
  z-index: 10;
}

.category-list {
  display: flex;
  flex-direction: row;
  padding: 16rpx 20rpx;
  white-space: nowrap;
}

.category-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #606266;
  background: #F5F7FA;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.category-item.active {
  background: #1677FF;
  color: #fff;
}

/* Map */
.map {
  flex: 1;
  width: 100%;
}

/* Hint bar */
.map-hint {
  position: absolute;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 22rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  pointer-events: none;
  z-index: 5;
}

/* Floating action buttons */
.fab-locate {
  position: absolute;
  right: 32rpx;
  bottom: 280rpx;
  width: 88rpx;
  height: 88rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.18);
  z-index: 20;
  font-size: 40rpx;
}

.fab-add {
  position: absolute;
  right: 32rpx;
  bottom: 180rpx;
  width: 88rpx;
  height: 88rpx;
  background: #1677FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.4);
  z-index: 20;
}

.fab-text {
  color: #fff;
  font-size: 56rpx;
  line-height: 88rpx;
  font-weight: 300;
}

/* Detail panel */
.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 50;
}

.detail-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  z-index: 60;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.12);
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #303133;
  flex: 1;
}

.detail-close {
  font-size: 36rpx;
  color: #909399;
  padding: 8rpx;
}

.detail-body {
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.detail-address,
.detail-note,
.detail-coord {
  font-size: 26rpx;
  color: #606266;
  margin-bottom: 12rpx;
  line-height: 1.6;
}

.detail-label {
  color: #909399;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
}

.detail-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 18rpx 0;
}
