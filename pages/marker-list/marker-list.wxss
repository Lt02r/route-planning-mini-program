/* pages/marker-list/marker-list.wxss */
.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 120rpx;
}

/* Search Bar */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 30rpx;
  padding: 12rpx 20rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #303133;
  height: 44rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #C0C4CC;
  flex-shrink: 0;
}

.sort-picker {
  flex-shrink: 0;
}

.sort-btn {
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 30rpx;
  padding: 12rpx 20rpx;
  gap: 8rpx;
  font-size: 24rpx;
  color: #606266;
}

.sort-arrow {
  font-size: 20rpx;
}

/* Category bar */
.category-bar {
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.category-list {
  display: flex;
  flex-direction: row;
  padding: 16rpx 20rpx;
  white-space: nowrap;
}

.category-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #606266;
  background: #F5F7FA;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.category-item.active {
  background: #1677FF;
  color: #fff;
}

/* Stats bar */
.stats-bar {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #909399;
}

/* Marker List */
.marker-list {
  padding: 0 24rpx;
}

.marker-card {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.marker-card-left {
  width: 24rpx;
  padding-top: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin: 0 auto;
}

.priority-dot-0 { background: #C0C4CC; }
.priority-dot-1 { background: #E6A23C; }
.priority-dot-2 { background: #F56C6C; }

.marker-card-body {
  flex: 1;
  min-width: 0;
}

.marker-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.marker-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
  flex: 1;
}

.marker-tags {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.marker-address,
.marker-note,
.marker-coord {
  font-size: 24rpx;
  color: #909399;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.marker-card-actions {
  flex-shrink: 0;
  padding: 8rpx;
  margin-left: 8rpx;
}

.delete-btn {
  font-size: 36rpx;
}

/* FAB */
.fab-add {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 96rpx;
  height: 96rpx;
  background: #1677FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.4);
  z-index: 20;
}

.fab-text {
  color: #fff;
  font-size: 56rpx;
  line-height: 96rpx;
}
